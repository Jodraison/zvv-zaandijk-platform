# Vul deze waarden in platform/.env.local (aanbevolen). Next.js en seed-scripts laden .env daarna .env.local.
# Supabase (verplicht — zie supabase/migrations/)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Alleen server/scripts: nooit in client-bundel. Storage-upload + seeds. Zie supabase/migrations/004_storage_team_bucket.sql
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Beheer: vaste eigenaar-e-mail + Auth user_metadata.role = "admin" (Dashboard → Authentication → Users).
# Geen extra env-variabele nodig; zie src/lib/auth/is-admin.ts.

# Optioneel: uitgebreide auth-log op de server (readDb, middleware, load failures)
# SUPABASE_DEBUG_AUTH=1

# Alleen migrate:club-atomic — directe Postgres (poort 5432), één transactie met ROLLBACK bij fout.
# Supabase: Project Settings → Database → Connection string → URI (niet transaction pooler).
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
