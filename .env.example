# Copy to .env.local (recommended) or .env. Next.js loads .env then .env.local.
# Never commit .env / .env.local with real keys.

# Supabase (required — see supabase/migrations/)
NEXT_PUBLIC_SUPABASE_URL=your-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-key

# Server only: storage uploads, seeds. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-secret

# Optional: verbose server auth logging (readDb, middleware)
# SUPABASE_DEBUG_AUTH=1

# Optional: migrate:club-atomic — direct Postgres (port 5432)
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
